# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and fill in with your actual values
# DO NOT commit .env to Git - it contains sensitive credentials
# 
# Usage:
#   1. cp .env.example .env
#   2. Edit .env with your actual values
#   3. python manage.py runserver (will auto-load from .env)
# ============================================================================

# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================
# Django environment: development, staging, or production
DJANGO_ENVIRONMENT=development
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production-min-50-chars-12345678

# Allowed hosts - comma separated for multiple hosts
# Examples: localhost,127.0.0.1,example.com,app.example.com
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.100

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL 16 Settings
DB_ENGINE=django.db.backends.postgresql
DB_NAME=proyek_management_job
DB_USER=manajemen_app_user
DB_PASSWORD=your-secure-password-change-this
DB_HOST=localhost
DB_PORT=5432

# Database connection pool settings (optional, for performance)
DB_CONN_MAX_AGE=600
DB_CONN_HEALTH_CHECK=true

# ============================================================================
# CACHING CONFIGURATION
# ============================================================================
# Cache backend: locmem (development) or redis (production)
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
# CACHE_BACKEND=django_redis.cache.RedisCache

# Redis configuration (if using Redis cache)
REDIS_URL=redis://localhost:6379/1
CACHE_TIMEOUT=3600

# Optional cache/log directories
LOG_DIR=C:/logs/management-job
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
CELERY_LOG_LEVEL=INFO

# ============================================================================
# CELERY & TASK QUEUE CONFIGURATION
# ============================================================================
# Celery broker and result backend
# Using Redis for both broker and result backend
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Celery timezone
CELERY_TIMEZONE=Asia/Jakarta

# ============================================================================
# STATIC & MEDIA FILES CONFIGURATION
# ============================================================================
# Storage location for uploaded files
# For Windows: C:\data\management-job\media
# For Linux: /var/data/management-job/media
MEDIA_ROOT=C:/data/management-job/media
MEDIA_URL=/media/

# Static files location (after collectstatic)
# For Windows: C:\data\management-job\static
# For Linux: /var/data/management-job/static
STATIC_ROOT=C:/data/management-job/static
STATIC_URL=/static/

# ============================================================================
# GOOGLE CALENDAR API INTEGRATION
# ============================================================================
# Path to Google Service Account credentials JSON file
GOOGLE_CALENDAR_CREDENTIALS_FILE=config/credentials/google-calendar-sa.json

# Google Calendar ID for meetings
# Example: ges3ra8851qk05jqlsfgjct3h4@group.calendar.google.com
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# ============================================================================
# WHATSAPP INTEGRATION - FONTTE API
# ============================================================================
# Fontte API token for WhatsApp message sending
# Get from: https://www.fontte.com/dashboard
FONTTE_API_TOKEN=your-fontte-api-token-here
FONTTE_API_BASE_URL=https://api.fontte.com/v1
FONTTE_API_ENABLED=true

# Alternative: Custom WABot API (if you have local WABot server)
# WABOT_API_URL=http://192.168.10.20:8000
# WABOT_API_KEY=your-wabot-api-key-here

# ============================================================================
# PUBLIC URL CONFIGURATION
# ============================================================================
# Public URL for generating share links
# For development: http://localhost:8000
# For ngrok: https://your-ngrok-url.ngrok-free.app
# For production: https://yourdomain.com
DJANGO_PUBLIC_URL=http://localhost:8000

# ============================================================================
# CSRF & CORS CONFIGURATION
# ============================================================================
# CSRF trusted origins - comma separated
# Used when serving behind reverse proxy (Caddy)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://yourdomain.com

# CSRF cookie security settings
CSRF_COOKIE_SECURE=true
CSRF_COOKIE_HTTPONLY=false

# Security headers
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
X_FRAME_OPTIONS=DENY

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================================
# Email backend: smtp (production) or console (development)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=webmaster@localhost

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
# Backup location for database dumps
# For Windows: C:\backup\management-job
# For Linux: /var/backup/management-job
BACKUP_PATH=C:/backup/management-job

# ============================================================================
# PERFORMANCE & OPTIMIZATION
# ============================================================================
# Database connection pooling
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Celery task timeout settings (in seconds)
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500

# ============================================================================
# TIMEZONE & LOCALIZATION
# ============================================================================
LANGUAGE_CODE=id
TIME_ZONE=Asia/Jakarta
USE_I18N=true
USE_TZ=true

# ============================================================================
# DEVELOPMENT TOOLS (Development Only)
# ============================================================================
# Maintenance mode
MAINTENANCE_MODE=false

# Shell Plus with IPython (django-extensions)
SHELL_PLUS_NOTEBOOK=false
